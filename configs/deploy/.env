# configs/deploy/.env.example
# Production environment variables.
# DO NOT commit real values — inject via GCP Secret Manager or Cloud Run --set-secrets.

DJANGO_SETTINGS_MODULE=settings
DJANGO_SECRET_KEY=REPLACE_WITH_SECRET_MANAGER_VALUE
DEBUG=False
ALLOWED_HOSTS=*

# ── Supabase ─────────────────────────────────────────────────────────────────
# Inject these as secrets in production (Cloud Run --set-secrets).
SUPABASE_URL=REPLACE_WITH_SECRET_MANAGER_VALUE
SUPABASE_ANON_KEY=REPLACE_WITH_SECRET_MANAGER_VALUE
SUPABASE_JWT_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
